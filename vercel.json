{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/world.js": { "maxDuration": 30 },
    "api/voice.js": { "maxDuration": 20 },
    "api/character.js": { "maxDuration": 10 },
    "api/contact.js": { "maxDuration": 10 },
    "api/session.js": { "maxDuration": 10 },
    "api/group.js": { "maxDuration": 10 },
    "api/shadow.js": { "maxDuration": 15 },
    "api/world-state.js": { "maxDuration": 15 },
    "api/idle.js": { "maxDuration": 60 },
    "api/notify.js": { "maxDuration": 10 }
  },
  "crons": [
    {
      "path": "/api/idle",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
