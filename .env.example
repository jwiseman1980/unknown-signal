# Unknown Signal — Environment Variables
# Copy this file to .env.local for local Vercel dev (vercel dev command).
# In production, set these in the Vercel dashboard under Project > Settings > Environment Variables.

# ─────────────────────────────────────────────
# REQUIRED — AI (narrative engine)
# ─────────────────────────────────────────────

# Anthropic API key — powers the Claude Sonnet narrative engine (api/world.js)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — powers The Echo's voice via TTS-1 (api/voice.js)
# Without this, voice falls back to browser Web Speech API automatically.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# REQUIRED for persistence — Vercel KV (Redis)
# ─────────────────────────────────────────────
# These are auto-populated when you attach a KV store in the Vercel dashboard.
# Vercel dashboard > Storage > Create KV Store > link to this project.
# Do not set these manually — Vercel injects them after linking.

KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-token

# Without KV, the game still works — contact numbering, session history,
# and cross-session character memory are disabled, but all gameplay functions.

# ─────────────────────────────────────────────
# OPTIONAL — Multiplayer / Linked Play (Ably)
# ─────────────────────────────────────────────
# Powers real-time shared narrative between two players.
# Get a free key at: https://ably.com → Apps → API Keys
# Without this, the group create/join flow works but no live sync.
ABLY_API_KEY=your-ably-key-here

# ─────────────────────────────────────────────
# REQUIRED for cron security — Idle Simulation
# ─────────────────────────────────────────────
# Protects the /api/idle cron endpoint from unauthorized calls.
# Set to any random string (openssl rand -hex 32).
# Must match the "Authorization: Bearer ..." header sent by Vercel cron.
CRON_SECRET=your-cron-secret-here
